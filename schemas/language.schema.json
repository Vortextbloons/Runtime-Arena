{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runtime-arena.dev/schemas/language.schema.json",
  "title": "LanguageManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "enabled",
    "detect",
    "build",
    "run",
    "sourceExtensions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "detect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "arguments"],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "arguments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workingDirectory", "command", "arguments", "artifact"],
      "properties": {
        "workingDirectory": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "arguments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifact": {
          "type": "string"
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "arguments"],
      "properties": {
        "command": {
          "type": "string"
        },
        "arguments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "sourceExtensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^\\.[a-z0-9]+$"
      },
      "uniqueItems": true
    }
  }
}
