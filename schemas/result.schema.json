{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runtime-arena.dev/schemas/result.schema.json",
  "title": "ArenaCanonicalSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "snapshotId",
    "updatedAt",
    "arenaVersion",
    "results"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "snapshotId": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "arenaVersion": {
      "type": "string"
    },
    "gitCommit": {
      "type": ["string", "null"]
    },
    "gitDirty": {
      "type": ["boolean", "null"]
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/benchmarkResult"
      }
    }
  },
  "$defs": {
    "benchmarkResult": {
      "type": "object",
      "required": [
        "benchmark",
        "dataset",
        "language",
        "build",
        "execution",
        "checker",
        "provenance"
      ],
      "properties": {
        "benchmark": {
          "type": "object",
          "required": ["id", "version", "size"],
          "properties": {
            "id": {
              "type": "string"
            },
            "version": {
              "type": "integer"
            },
            "size": {
              "type": "string"
            },
            "mutation": {
              "type": "string"
            }
          }
        },
        "dataset": {
          "type": "object",
          "required": ["id", "sha256"],
          "properties": {
            "id": {
              "type": "string"
            },
            "sha256": {
              "type": "string"
            },
            "seed": {
              "type": "integer"
            },
            "mutation": {
              "type": "string"
            },
            "generatorVersion": {
              "type": "string"
            }
          }
        },
        "language": {
          "type": "object",
          "required": ["id", "name", "version"],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "compilerVersion": {
              "type": "string"
            }
          }
        },
        "build": {
          "type": "object",
          "required": ["status", "durationNanoseconds", "command"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["success", "cached", "failed", "skipped"]
            },
            "durationNanoseconds": {
              "type": "integer",
              "minimum": 0
            },
            "artifactSizeBytes": {
              "type": "integer",
              "minimum": 0
            },
            "command": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "execution": {
          "type": "object",
          "required": [
            "mode",
            "measurementContractVersion",
            "totalProcessDurationNanoseconds",
            "warmupIterations",
            "measuredIterations",
            "samples",
            "summary"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "const": "persistent-worker"
            },
            "measurementContractVersion": {
              "type": "string",
              "enum": ["1.0.0", "1.1.0"]
            },
            "totalProcessDurationNanoseconds": {
              "type": "integer",
              "minimum": 0
            },
            "warmupIterations": {
              "type": "integer",
              "minimum": 0
            },
            "measuredIterations": {
              "type": "integer",
              "minimum": 0
            },
            "measurement": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "mode",
                "minMeasuredIterations",
                "maxMeasuredIterations",
                "targetRelativeConfidenceInterval"
              ],
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["adaptive-confidence-interval", "fixed"]
                },
                "minMeasuredIterations": {
                  "type": "integer",
                  "minimum": 1
                },
                "maxMeasuredIterations": {
                  "type": "integer",
                  "minimum": 1
                },
                "targetRelativeConfidenceInterval": {
                  "type": "number",
                  "minimum": 0
                }
              }
            },
            "samples": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/sample"
              }
            },
            "summary": {
              "type": "object",
              "required": ["validSamples"],
              "properties": {
                "validSamples": {
                  "type": "integer",
                  "minimum": 0
                },
                "medianKernelTimeNanoseconds": {
                  "type": "integer"
                },
                "minimumKernelTimeNanoseconds": {
                  "type": "integer"
                },
                "maximumKernelTimeNanoseconds": {
                  "type": "integer"
                },
                "p95KernelTimeNanoseconds": {
                  "type": "integer"
                }
              }
            },
            "startup": {
              "type": "object",
              "additionalProperties": false,
              "required": ["durationNanoseconds", "mode"],
              "description": "Explicit process/runtime startup, separate from kernel workload time.",
              "properties": {
                "durationNanoseconds": { "type": "integer", "minimum": 0 },
                "mode": { "type": "string", "minLength": 1 }
              }
            },
            "memory": {
              "type": "object",
              "additionalProperties": false,
              "required": ["peakResidentBytes", "collector"],
              "description": "Peak resident memory with collector identity for cross-language comparison.",
              "properties": {
                "peakResidentBytes": { "type": "integer", "minimum": 0 },
                "collector": { "type": "string", "minLength": 1 }
              }
            },
            "memoryCollector": {
              "type": "string",
              "description": "Legacy alias for memory.collector when sample peakMemoryBytes is used."
            },
            "parallel": {
              "type": "object",
              "additionalProperties": false,
              "required": ["workerCount", "singleWorkerBaselineNanoseconds", "multiWorkerNanoseconds"],
              "description": "Parallel scaling samples for the Parallelism card attribute.",
              "properties": {
                "workerCount": { "type": "integer", "minimum": 1 },
                "singleWorkerBaselineNanoseconds": { "type": "integer", "minimum": 0 },
                "multiWorkerNanoseconds": { "type": "integer", "minimum": 0 }
              }
            }
          }
        },
        "checker": {
          "type": "object",
          "required": ["language", "version", "status"],
          "properties": {
            "language": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "accepted",
                "wrong-answer",
                "malformed-output",
                "unsupported-version",
                "checker-error"
              ]
            },
            "diagnostics": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["fingerprint", "measurementContractVersion", "measuredAt", "machine"],
          "properties": {
            "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "measurementContractVersion": { "type": "string", "enum": ["1.0.0", "1.1.0"] },
            "measuredAt": { "type": "string", "format": "date-time" },
            "machine": {
              "type": "object",
              "required": ["operatingSystem", "cpu", "memoryBytes"],
              "properties": {
                "operatingSystem": {
                  "type": "object",
                  "required": ["platform", "release"],
                  "properties": {
                    "platform": { "type": "string" },
                    "release": { "type": "string" }
                  }
                },
                "cpu": {
                  "type": "object",
                  "required": ["model", "architecture", "logicalCores"],
                  "properties": {
                    "model": { "type": "string" },
                    "architecture": { "type": "string" },
                    "logicalCores": { "type": "integer", "minimum": 1 }
                  }
                },
                "memoryBytes": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["iteration", "valid", "kernelTimeNanoseconds", "exitCode"],
      "properties": {
        "iteration": {
          "type": "integer",
          "minimum": 1
        },
        "valid": {
          "type": "boolean"
        },
        "kernelTimeNanoseconds": {
          "type": "integer",
          "minimum": 0
        },
        "cpuTimeNanoseconds": {
          "type": "integer",
          "minimum": 0
        },
        "peakMemoryBytes": {
          "type": "integer",
          "minimum": 0
        },
        "exitCode": {
          "type": "integer"
        },
        "outputSizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "timedOut": { "type": "boolean" },
        "outputLimitExceeded": { "type": "boolean" }
      }
    }
  }
}
