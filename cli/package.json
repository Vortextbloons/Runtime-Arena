{
  "name": "@runtime-arena/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Runtime Arena command-line benchmark runner",
  "type": "module",
  "bin": {
    "arena": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "arena": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"test/**/*.test.ts\""
  },
  "engines": {
    "node": ">=26.4.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
