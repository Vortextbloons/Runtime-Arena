{
  "$schema": "../../schemas/benchmark.schema.json",
  "id": "aggregation",
  "name": "Structured-data aggregation",
  "version": 1,
  "description": "CSV-style record aggregation exercising parsing, allocation, hash maps, sorting, and garbage collection.",
  "inputFormat": "csv",
  "outputFormat": "json",
  "checker": {
    "task": "aggregation",
    "timeoutMilliseconds": 30000
  },
  "sizes": {
    "small": {
      "dataset": "small.csv",
      "warmupIterations": 3,
      "measuredIterations": 10
    },
    "medium": {
      "dataset": "medium.csv",
      "warmupIterations": 3,
      "measuredIterations": 10
    },
    "large": {
      "dataset": "large.csv",
      "warmupIterations": 3,
      "measuredIterations": 10
    }
  },
  "metrics": ["kernelTime"],
  "limits": {
    "timeoutMilliseconds": 120000,
    "maxOutputBytes": 10485760
  }
}
