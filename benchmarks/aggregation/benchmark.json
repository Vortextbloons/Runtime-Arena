{
  "$schema": "../../schemas/benchmark.schema.json",
  "id": "aggregation",
  "name": "Structured-data aggregation",
  "version": 1,
  "description": "In-memory transaction aggregation over CSV input exercising hash maps, sorting, checksums, and garbage collection. CSV parsing happens before the timed kernel.",
  "inputFormat": "csv",
  "outputFormat": "json",
  "checker": {
    "task": "aggregation",
    "timeoutMilliseconds": 30000
  },
  "sizes": {
    "small": {
      "dataset": "small.csv",
      "warmupIterations": 2,
      "measuredIterations": 5
    },
    "medium": {
      "dataset": "medium.csv",
      "warmupIterations": 2
    },
    "large": {
      "dataset": "large.csv",
      "warmupIterations": 2
    }
  },
  "metrics": ["kernelTime"],
  "limits": {
    "timeoutMilliseconds": 120000,
    "maxOutputBytes": 10485760
  }
}
