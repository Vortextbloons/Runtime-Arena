{
  "$schema": "../../schemas/benchmark.schema.json",
  "id": "word-frequency",
  "name": "Word frequency",
  "version": 1,
  "description": "Prepared-word frequency counting exercising string hashing, hash maps, allocation, ranking, and dynamic-language object overhead.",
  "inputFormat": "json",
  "outputFormat": "json",
  "checker": { "task": "word-frequency", "timeoutMilliseconds": 30000 },
  "sizes": {
    "small": { "dataset": "small.json", "warmupIterations": 3, "measuredIterations": 10 },
    "medium": { "dataset": "medium.json", "warmupIterations": 3, "measuredIterations": 10 },
    "large": { "dataset": "large.json", "warmupIterations": 3, "measuredIterations": 10 }
  },
  "metrics": ["kernelTime"],
  "limits": { "timeoutMilliseconds": 120000, "maxOutputBytes": 10485760 }
}
