{
  "$schema": "../../schemas/benchmark.schema.json",
  "id": "shortest-path",
  "name": "Weighted shortest-path queries",
  "version": 1,
  "description": "Directed weighted graph shortest-path queries exercising priority queues, memory access, and branch-heavy workloads.",
  "inputFormat": "json",
  "outputFormat": "json",
  "checker": {
    "task": "shortest-path",
    "timeoutMilliseconds": 30000
  },
  "sizes": {
    "small": {
      "warmupIterations": 2,
      "measuredIterations": 5,
      "mutations": {
        "sparse": { "dataset": "small-sparse.json", "seed": 729418 },
        "dense": { "dataset": "small-dense.json", "seed": 729418 }
      }
    },
    "medium": {
      "warmupIterations": 2,
      "measuredIterations": 3,
      "mutations": {
        "sparse": { "dataset": "medium-sparse.json", "seed": 729418 },
        "dense": { "dataset": "medium-dense.json", "seed": 729418 }
      }
    },
    "large": {
      "warmupIterations": 2,
      "measuredIterations": 3,
      "mutations": {
        "sparse": { "dataset": "large-sparse.json", "seed": 729418 },
        "dense": { "dataset": "large-dense.json", "seed": 729418 }
      }
    }
  },
  "metrics": ["kernelTime"],
  "limits": {
    "timeoutMilliseconds": 120000,
    "maxOutputBytes": 10485760
  }
}
