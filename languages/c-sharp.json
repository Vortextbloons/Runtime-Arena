{
  "$schema": "../schemas/language.schema.json",
  "id": "c-sharp",
  "name": "C#",
  "enabled": true,
  "detect": {
    "command": "dotnet",
    "arguments": ["--version"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "node",
    "arguments": [
      "{projectRoot}/scripts/build-csharp.mjs",
      "--output",
      ".arena/{benchmarkId}.dll",
      "Program.cs"
    ],
    "artifact": ".arena/{benchmarkId}.dll"
  },
  "run": {
    "command": "dotnet",
    "arguments": [
      "{artifact}",
      "--input", "{inputFile}",
      "--output", "{outputFile}",
      "--protocol-version", "{protocolVersion}"
    ]
  },
  "environment": {
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    "DOTNET_NOLOGO": "1"
  },
  "sourceExtensions": [".cs"],
  "provenance": {
    "environmentAllowlist": ["DOTNET_CLI_TELEMETRY_OPTOUT", "DOTNET_NOLOGO", "DOTNET_ROOT"],
    "externalInputs": [
      { "path": "{projectRoot}/scripts/build-csharp.mjs" }
    ],
    "probes": [
      { "id": "dotnet", "command": "dotnet", "arguments": ["--version"] }
    ]
  }
}
