{
  "$schema": "../schemas/language.schema.json",
  "id": "rust",
  "name": "Rust",
  "enabled": true,
  "detect": {
    "command": "rustc",
    "arguments": ["--version"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "cargo",
    "arguments": ["build", "--release"],
    "artifact": "target/release/{benchmarkId}"
  },
  "run": {
    "command": "{artifact}",
    "arguments": [
      "--input",
      "{inputFile}",
      "--output",
      "{outputFile}",
      "--protocol-version",
      "{protocolVersion}"
    ]
  },
  "environment": {},
  "sourceExtensions": [".rs"],
  "resourceBundle": { "sourceInclude": ["**/*.rs"], "sourceExclude": ["**/.arena/**", "**/target/**"], "artifactInclude": ["**/*"], "artifactExclude": [] },
  "provenance": {
    "environmentAllowlist": [],
    "externalInputs": [
      { "path": "{implementationDir}/Cargo.toml" },
      { "path": "{implementationDir}/Cargo.lock" }
    ],
    "probes": [
      { "id": "compiler", "command": "rustc", "arguments": ["--version"] },
      { "id": "cargo", "command": "cargo", "arguments": ["--version"] }
    ]
  }
}
