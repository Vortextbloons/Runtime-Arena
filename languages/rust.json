{
  "$schema": "../schemas/language.schema.json",
  "id": "rust",
  "name": "Rust",
  "enabled": true,
  "detect": {
    "command": "rustc",
    "arguments": ["--version"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "cargo",
    "arguments": ["build", "--release"],
    "artifact": "target/release/{benchmarkId}"
  },
  "run": {
    "command": "{artifact}",
    "arguments": [
      "--input",
      "{inputFile}",
      "--output",
      "{outputFile}",
      "--timing-output",
      "{timingOutputFile}",
      "--warmup",
      "{warmupIterations}",
      "--min-iterations",
      "{minMeasuredIterations}",
      "--max-iterations",
      "{maxMeasuredIterations}",
      "--target-relative-ci",
      "{targetRelativeConfidenceInterval}"
    ]
  },
  "environment": {},
  "sourceExtensions": [".rs"]
}
