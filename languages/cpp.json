{
  "$schema": "../schemas/language.schema.json",
  "id": "cpp",
  "name": "C++",
  "enabled": true,
  "detect": {
    "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
    "arguments": ["--version"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
    "arguments": ["-O3", "-std=c++23", "-I", "../../../../languages/cpp/include", "-o", "{artifact}", "main.cpp", "-lpthread", "-lsynchronization"],
    "artifact": "{benchmarkId}"
  },
  "run": {
    "command": "{artifact}",
    "arguments": [
      "--input", "{inputFile}",
      "--output", "{outputFile}",
      "--timing-output", "{timingOutputFile}",
      "--warmup", "{warmupIterations}",
      "--min-iterations", "{minMeasuredIterations}",
      "--max-iterations", "{maxMeasuredIterations}",
      "--target-relative-ci", "{targetRelativeConfidenceInterval}"
    ]
  },
  "environment": {
    "PATH": "C:\\msys64\\ucrt64\\bin;{PATH}"
  },
  "sourceExtensions": [".cpp", ".hpp", ".h"]
}
