{
  "$schema": "../schemas/language.schema.json",
  "id": "lua-interpreted",
  "name": "Lua Interpreted",
  "enabled": true,
  "detect": {
    "command": "C:\\Users\\isaac\\AppData\\Local\\Programs\\Lua\\bin\\lua.exe",
    "arguments": ["-v"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "C:\\Users\\isaac\\AppData\\Local\\Programs\\Lua\\bin\\lua.exe",
    "arguments": ["-e", "do end"],
    "artifact": "main.lua"
  },
  "run": {
    "command": "C:\\Users\\isaac\\AppData\\Local\\Programs\\Lua\\bin\\lua.exe",
    "arguments": [
      "{artifact}",
      "--input",
      "{inputFile}",
      "--output",
      "{outputFile}",
      "--protocol-version",
      "{protocolVersion}"
    ]
  },
  "environment": {},
  "sourceExtensions": [".lua"],
  "provenance": {
    "probes": [
      { "id": "runtime", "command": "C:\\Users\\isaac\\AppData\\Local\\Programs\\Lua\\bin\\lua.exe", "arguments": ["-v"] }
    ]
  }
}
