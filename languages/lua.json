{
  "$schema": "../schemas/language.schema.json",
  "id": "lua",
  "name": "LuaJIT",
  "enabled": true,
  "detect": {
    "command": "C:\\Users\\isaac\\AppData\\Local\\Programs\\LuaJIT\\bin\\luajit.exe",
    "arguments": ["-v"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "C:\\Users\\isaac\\AppData\\Local\\Programs\\LuaJIT\\bin\\luajit.exe",
    "arguments": ["-b", "main.lua", "NUL"],
    "artifact": "main.lua"
  },
  "run": {
    "command": "C:\\Users\\isaac\\AppData\\Local\\Programs\\LuaJIT\\bin\\luajit.exe",
    "arguments": [
      "{artifact}",
      "--input",
      "{inputFile}",
      "--output",
      "{outputFile}",
      "--protocol-version",
      "{protocolVersion}"
    ]
  },
  "environment": {},
  "sourceExtensions": [".lua"],
  "resourceBundle": { "sourceInclude": ["**/*.lua"], "sourceExclude": ["**/.arena/**"], "artifactInclude": ["**/*.lua"], "artifactExclude": [] },
  "provenance": {
    "probes": [
      { "id": "runtime", "command": "C:\\Users\\isaac\\AppData\\Local\\Programs\\LuaJIT\\bin\\luajit.exe", "arguments": ["-v"] }
    ]
  }
}
