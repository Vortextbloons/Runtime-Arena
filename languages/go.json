{
  "$schema": "../schemas/language.schema.json",
  "id": "go",
  "name": "Go",
  "enabled": true,
  "detect": {
    "command": "go",
    "arguments": ["version"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "go",
    "arguments": [
      "build",
      "-ldflags=-s -w",
      "-o",
      "{artifact}",
      "."
    ],
    "artifact": ".arena/{benchmarkId}"
  },
  "run": {
    "command": "{artifact}",
    "arguments": [
      "--input",
      "{inputFile}",
      "--output",
      "{outputFile}",
      "--protocol-version",
      "{protocolVersion}"
    ]
  },
  "environment": {},
  "sourceExtensions": [".go"],
  "resourceBundle": { "sourceInclude": ["**/*.go"], "sourceExclude": ["**/.arena/**"], "artifactInclude": ["**/*"], "artifactExclude": [] },
  "provenance": {
    "environmentAllowlist": ["GOCACHE", "GOOS", "GOARCH"],
    "externalInputs": [
      { "path": "{implementationDir}/go.mod" },
      { "path": "{implementationDir}/go.sum" }
    ],
    "probes": [
      { "id": "compiler", "command": "go", "arguments": ["version"] }
    ]
  }
}
