{
  "$schema": "../schemas/language.schema.json",
  "id": "java",
  "name": "Java",
  "enabled": true,
  "detect": {
    "command": "javac",
    "arguments": ["--version"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "node",
    "arguments": [
      "{projectRoot}/scripts/build-java.mjs",
      "--release",
      "17",
      "--output",
      ".arena/{benchmarkId}.jar",
      "Main.java"
    ],
    "artifact": ".arena/{benchmarkId}.jar"
  },
  "run": {
    "command": "java",
    "arguments": [
      "-cp",
      "{artifact}",
      "Main",
      "--input",
      "{inputFile}",
      "--output",
      "{outputFile}",
      "--protocol-version",
      "{protocolVersion}"
    ]
  },
  "environment": {},
  "sourceExtensions": [".java"],
  "provenance": {
    "environmentAllowlist": ["JAVA_HOME"],
    "externalInputs": [
      { "path": "{projectRoot}/scripts/build-java.mjs" }
    ],
    "probes": [
      { "id": "javac", "command": "javac", "arguments": ["--version"] },
      { "id": "java", "command": "java", "arguments": ["--version"] }
    ]
  }
}
