{
  "$schema": "../schemas/language.schema.json",
  "id": "typescript",
  "name": "TypeScript",
  "enabled": true,
  "detect": {
    "command": "node",
    "arguments": ["--version"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "node",
    "arguments": [
      "{projectRoot}/node_modules/typescript/bin/tsc",
      "--project",
      "tsconfig.json"
    ],
    "artifact": "dist/index.js"
  },
  "run": {
    "command": "node",
    "arguments": [
      "{artifact}",
      "--input",
      "{inputFile}",
      "--output",
      "{outputFile}",
      "--protocol-version",
      "{protocolVersion}"
    ]
  },
  "environment": {
    "NODE_ENV": "production"
  },
  "sourceExtensions": [".ts"],
  "resourceBundle": { "sourceInclude": ["**/*.ts"], "sourceExclude": ["**/.arena/**", "**/node_modules/**"], "artifactInclude": ["**/*.mjs", "**/*.js"], "artifactExclude": ["**/node_modules/**"] },
  "provenance": {
    "environmentAllowlist": ["NODE_ENV"],
    "externalInputs": [
      { "path": "{implementationDir}/package.json" },
      { "path": "{implementationDir}/package-lock.json" },
      { "path": "{implementationDir}/tsconfig.json" },
      { "path": "{projectRoot}/node_modules/typescript/package.json" }
    ],
    "probes": [
      { "id": "node", "command": "node", "arguments": ["--version"] },
      { "id": "typescript", "command": "node", "arguments": ["{projectRoot}/node_modules/typescript/bin/tsc", "--version"] }
    ]
  }
}
