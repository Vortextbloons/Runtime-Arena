{
  "$schema": "../schemas/language.schema.json",
  "id": "javascript",
  "name": "JavaScript",
  "enabled": true,
  "detect": {
    "command": "node",
    "arguments": ["--version"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "node",
    "arguments": ["-e", "0"],
    "artifact": "index.mjs"
  },
  "run": {
    "command": "node",
    "arguments": [
      "{artifact}",
      "--input",
      "{inputFile}",
      "--output",
      "{outputFile}",
      "--protocol-version",
      "{protocolVersion}"
    ]
  },
  "environment": {
    "NODE_ENV": "production"
  },
  "sourceExtensions": [".mjs"],
  "provenance": {
    "environmentAllowlist": ["NODE_ENV"],
    "probes": [
      { "id": "node", "command": "node", "arguments": ["--version"] }
    ]
  }
}
