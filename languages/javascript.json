{
  "$schema": "../schemas/language.schema.json",
  "id": "javascript",
  "name": "JavaScript",
  "enabled": true,
  "detect": {
    "command": "node",
    "arguments": ["--version"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "node",
    "arguments": ["-e", "0"],
    "artifact": "index.mjs"
  },
  "run": {
    "command": "node",
    "arguments": [
      "{artifact}",
      "--input",
      "{inputFile}",
      "--output",
      "{outputFile}",
      "--timing-output",
      "{timingOutputFile}",
      "--warmup",
      "{warmupIterations}",
      "--iterations",
      "{measuredIterations}"
    ]
  },
  "environment": {
    "NODE_ENV": "production"
  },
  "sourceExtensions": [".mjs"]
}
