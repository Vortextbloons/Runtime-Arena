{
  "$schema": "../schemas/language.schema.json",
  "id": "python",
  "name": "Python",
  "enabled": true,
  "detect": {
    "command": "python",
    "arguments": ["--version"]
  },
  "build": {
    "workingDirectory": "{implementationDir}",
    "command": "python",
    "arguments": ["-m", "py_compile", "main.py"],
    "artifact": "main.py"
  },
  "run": {
    "command": "python",
    "arguments": [
      "{artifact}",
      "--input",
      "{inputFile}",
      "--output",
      "{outputFile}",
      "--protocol-version",
      "{protocolVersion}"
    ]
  },
  "environment": {},
  "sourceExtensions": [".py"],
  "resourceBundle": { "sourceInclude": ["**/*.py"], "sourceExclude": ["**/.arena/**", "**/__pycache__/**"], "artifactInclude": ["**/*.py"], "artifactExclude": ["**/__pycache__/**"] },
  "provenance": {
    "environmentAllowlist": ["PYTHONHASHSEED"],
    "probes": [
      { "id": "runtime", "command": "python", "arguments": ["--version"] }
    ]
  }
}
